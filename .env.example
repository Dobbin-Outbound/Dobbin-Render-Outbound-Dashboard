# =============================================================
# Outbound Dashboard - environment template
# Copy to .env for local dev. On Render, set these in the
# service's Environment tab (never commit real values).
# Every var below is read by the code (app.py / *_client.py /
# gemini_evaluator.py). [CLIENT] = swap per client.
# =============================================================

# --- App / Auth ---
SECRET_KEY=                      # random 32+ char string (flask session signing)
DASHBOARD_USERNAME=admin         # [CLIENT] login user
DASHBOARD_PASSWORD=changeme      # [CLIENT] login password

# --- HeyReach (LinkedIn outreach) ---
HEYREACH_API_KEY=                # [CLIENT] HeyReach API key
HEYREACH_BASE_URL=https://api.heyreach.io
HEYREACH_SENDER_IDS=[]           # [CLIENT] JSON array, e.g. [120478, 186717]
HEYREACH_SENDER_NAMES={}         # [CLIENT] JSON map id->name, e.g. {"120478": "Jane Doe"}

# --- Supabase (message store + KPIs) ---
SUPABASE_URL=                    # [CLIENT] https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=       # [CLIENT] service role key (server-side only)

# --- AI reply classifier (OpenRouter primary, Gemini fallback) ---
OPENROUTER_API_KEY=              # [CLIENT or shared] OpenRouter key
AI_MODEL=google/gemini-2.5-flash # optional, swap model w/o code change
GEMINI_API_KEY=                  # optional fallback if only Gemini key is set

# --- Pipedrive (CRM sync, optional) ---
PIPEDRIVE_API_TOKEN=             # [CLIENT] Pipedrive token
PIPEDRIVE_COMPANY_DOMAIN=        # [CLIENT] e.g. yourco (from *.pipedrive.com)
PIPEDRIVE_MEETING_STAGES=        # optional: stage ids/names counted as "meeting booked"

# --- Instantly (email outreach, future) ---
INSTANTLY_API_KEY=               # [CLIENT] optional

# --- Runtime ---
PORT=10000                       # Render sets this automatically
